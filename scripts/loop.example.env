#!/usr/bin/env bash
#
# loop.example.env — a documented, runnable example invocation of the loop
# driver. Copy it, edit the variables for your throwaway target, then run:
#
#     bash scripts/loop.example.env
#
# The headless `claude` flags are NOT respecified here: they are pinned inside
# scripts/loop.sh (the single source) so this example and the driver can never
# diverge. For the record, loop.sh launches the run as:
#
#     env -i HOME=... PATH=... [GH_TOKEN=...] \
#       claude -p "<lfg routing prompt + seed>" \
#         --plugin-dir <plugin> --model <model> --dangerously-skip-permissions
#
# Confirm the exact constructed command at any time with `--dry-run` (below).
#
# NOTE (execution-time unknown): the precise headless trigger form — this inline
# routing prompt vs. a `/lfg` slash command, and long multi-turn behavior — is
# pinned by the live acceptance smoke (docs/loop-driver-acceptance.md). If that
# smoke changes the form, change it in loop.sh (LOOP_PROMPT_PREFIX) only; this
# file needs no edit.

set -euo pipefail
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"

# --- Edit these for your throwaway target ------------------------------------
TARGET="${TARGET:-/absolute/path/to/throwaway-repo}"   # must be OUTSIDE this plugin checkout
SEED_FILE="${SEED_FILE:-$HERE/../examples/loop-seed.md}"
MODEL="${MODEL:-opus}"          # opus or fable
TIMEOUT="${TIMEOUT:-1800}"      # per-attempt wall-clock seconds
MAX_RETRIES="${MAX_RETRIES:-2}" # re-launches after a crash-without-DONE

# --- Verification mode (pick ONE) --------------------------------------------
# Faithful GitHub-CI bar (recommended for sign-off): leave --verify-cmd off and
# give the throwaway a remote + the sample Actions workflow. loop.sh then gates
# success on an open PR with green `gh pr checks`.
#
# Local proxy (no Actions needed): append  --verify-cmd bun test
# to the invocation below to prove the mechanism without standing up CI.

# Print the exact command first (no execution), then run it for real.
bash "$HERE/loop.sh" \
  --target "$TARGET" \
  --seed-file "$SEED_FILE" \
  --model "$MODEL" \
  --timeout "$TIMEOUT" \
  --max-retries "$MAX_RETRIES" \
  --dry-run

bash "$HERE/loop.sh" \
  --target "$TARGET" \
  --seed-file "$SEED_FILE" \
  --model "$MODEL" \
  --timeout "$TIMEOUT" \
  --max-retries "$MAX_RETRIES"
